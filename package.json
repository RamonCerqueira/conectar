{
  "name": "conectar",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Gestão Clínica — Instituto Conectar",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "frontend": "turbo run dev --filter=frontend",
    "backend": "turbo run dev --filter=backend",
    "landingpage": "turbo run dev --filter=landingpage",
    "ai-service": "turbo run dev --filter=ai-service",
    "whatsapp-service": "turbo run dev --filter=whatsapp-service",
    "sync-env": "node scripts/sync-env.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "turbo run db:migrate --filter=backend",
    "db:generate": "turbo run db:generate --filter=backend",
    "db:studio": "turbo run db:studio --filter=backend",
    "db:seed": "turbo run db:seed --filter=backend"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4"
}
