# ═══════════════════════════════════════════════════════════════
#  Instituto Conectar — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=db.mwhxwuorzmigwdskokfi.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=conectar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=RamonDev123Conectar

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@localhost:6379

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=TROQUE_ESTA_CHAVE_JWT_EM_PRODUCAO_MIN_64_CHARS
JWT_REFRESH_SECRET=TROQUE_ESTA_CHAVE_REFRESH_EM_PRODUCAO_MIN_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Aplicação ────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=8001
FRONTEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8001

# ─── Google Gemini IA ─────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.0-flash-exp

# ─── Armazenamento Local ───────────────────────────────────────
STORAGE_PATH=./storage
STORAGE_MAX_FILE_SIZE=52428800  # 50MB em bytes

# ─── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=clinica@institutoconectar.com.br
SMTP_PASS=sua_senha_de_app_aqui
SMTP_FROM="Instituto Conectar <clinica@institutoconectar.com.br>"

# ─── WhatsApp (Microserviço) ──────────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:8002
WHATSAPP_SESSION_ID=conectar-session

# ─── Clínica ──────────────────────────────────────────────────
CLINICA_NOME=Instituto Conectar
CLINICA_CNPJ=00.000.000/0001-00
CLINICA_TELEFONE=(00) 0000-0000
CLINICA_EMAIL=contato@institutoconectar.com.br
CLINICA_ENDERECO=Rua Exemplo, 123 - Cidade/UF

# ─── Segurança ────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
COOKIE_SECRET=TROQUE_ESTE_SEGREDO_DE_COOKIE_EM_PRODUCAO

# ─── Frontend (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=Instituto Conectar
